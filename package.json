{
  "name": "nexus-system",
  "version": "1.8.2",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByelBardini/nexus-system.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run start:dev --prefix server\" \"npm run dev --prefix client\"",
    "start": "concurrently -n server,client -c cyan,magenta \"npm run start:server\" \"npm run start:client\"",
    "db:sync-permissions": "npm run prisma:sync-permissions --prefix server",
    "dev:server": "npm run start:dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build:client": "cd client && npm install && npm run build",
    "start:client": "cd client && npm run start",
    "build:server": "cd server && npm install && npm run build",
    "start:server": "cd server && npm run start:prod",
    "format": "npm run format --prefix server && npm run format --prefix client",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "sync-versions": "node scripts/sync-package-versions.mjs",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "concurrently": "^9.1.2",
    "release-it": "^19.2.2",
    "semantic-release": "^25.0.3"
  }
}
