{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "Bash(npx eslint . --quiet *)",
      "Bash(npm run test *)",
      "Bash(npm run *)",
      "Bash(npx jest *)",
      "Bash(npx --prefix * jest *)",
      "Bash(npx prisma *)",
      "Bash(npm show *)",
      "Bash(npm audit *)",
      "Bash(./node_modules/.bin/tsc *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(xargs grep *)",
      "Bash(rm -rf node_modules*)",
      "Bash(rm -rf dist*)",
      "Bash(rm -rf .next*)",
      "Bash(rm -rf coverage*)",
      "Bash(npx prettier *)"
    ],
    "additionalDirectories": [
      "d:\\nexus-system\\.claude\\plans"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-verify.sh",
            "timeout": 120,
            "statusMessage": "Verifying edit..."
          }
        ]
      },
      {
        "matcher": "Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/truncation-check.sh",
            "timeout": 5,
            "statusMessage": "Checking for truncation..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-destructive.sh",
            "timeout": 5,
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ]
  }
}
