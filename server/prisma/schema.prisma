generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id              Int            @id @default(autoincrement())
  nome            String         @db.VarChar(200)
  email           String         @unique @db.VarChar(255)
  senhaHash       String         @map("senha_hash") @db.VarChar(255)
  ativo           Boolean        @default(true)
  setor           SetorUsuario?
  ultimoAcesso    DateTime?      @map("ultimo_acesso")
  senhaExpiradaEm DateTime?      @map("senha_expirada_em")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  ordensServico      OrdemServico[]
  usuarioCargos      UsuarioCargo[]
  pedidosRastreadores PedidoRastreador[]

  @@map("usuarios")
}

enum SetorUsuario {
  AGENDAMENTO
  CONFIGURACAO
  ADMINISTRATIVO
}

model Setor {
  id     Int     @id @default(autoincrement())
  code   String  @unique @db.VarChar(50)
  nome   String  @db.VarChar(100)
  cargos Cargo[]

  @@map("setores")
}

model Cargo {
  id              Int              @id @default(autoincrement())
  setorId         Int              @map("sector_id")
  code            String           @db.VarChar(50)
  nome            String           @db.VarChar(100)
  descricao       String?          @db.VarChar(500)
  categoria       CategoriaCargo   @default(OPERACIONAL)
  ativo           Boolean          @default(true)
  setor           Setor            @relation(fields: [setorId], references: [id], onDelete: Cascade)
  cargoPermissoes CargoPermissao[]
  usuarioCargos   UsuarioCargo[]

  @@unique([setorId, code])
  @@map("cargos")
}

enum CategoriaCargo {
  OPERACIONAL
  ADMINISTRATIVO
  GESTAO
}

model Permissao {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(100)
  cargoPermissoes CargoPermissao[]

  @@map("permissoes")
}

model CargoPermissao {
  cargoId     Int       @map("role_id")
  permissaoId Int       @map("permission_id")
  permissao   Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)
  cargo       Cargo     @relation(fields: [cargoId], references: [id], onDelete: Cascade)

  @@id([cargoId, permissaoId])
  @@index([permissaoId], map: "cargos_permissoes_permission_id_fkey")
  @@map("cargos_permissoes")
}

model UsuarioCargo {
  usuarioId Int     @map("user_id")
  cargoId   Int     @map("role_id")
  cargo     Cargo   @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([usuarioId, cargoId])
  @@index([cargoId], map: "usuarios_cargos_role_id_fkey")
  @@map("usuarios_cargos")
}

model RegistroAuditoria {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?     @map("user_id")
  action      String   @db.VarChar(50)
  entity      String   @db.VarChar(100)
  entityId    Int?     @map("entity_id")
  createdAt   DateTime @default(now()) @map("created_at")
  payloadJson String?  @map("payload_json") @db.Text

  @@map("registros_auditoria")
}

model Cliente {
  id                         Int                @id @default(autoincrement())
  nome                       String             @db.VarChar(200)
  nomeFantasia               String?            @map("nome_fantasia") @db.VarChar(200)
  cnpj                       String?            @db.VarChar(20)
  tipoContrato               TipoContrato       @default(COMODATO) @map("tipo_contrato")
  estoqueProprio             Boolean            @default(false) @map("estoque_proprio")
  status                     StatusCliente      @default(ATIVO)
  cep                        String?            @db.VarChar(10)
  logradouro                 String?            @db.VarChar(255)
  numero                     String?            @db.VarChar(20)
  complemento                String?            @db.VarChar(100)
  bairro                     String?            @db.VarChar(100)
  cidade                     String?            @db.VarChar(100)
  estado                     String?            @db.VarChar(2)
  contatos                   ContatoCliente[]
  ordensServico              OrdemServico[]
  subclientes                Subcliente[]
  aparelhos                  Aparelho[]
  lotesAparelhos             LoteAparelho[]
  pedidosRastreadoresDestino   PedidoRastreador[] @relation("ClienteDestino")
  pedidosRastreadoresDeCliente PedidoRastreador[] @relation("ClienteRemetente")

  @@map("clientes")
}

enum TipoContrato {
  COMODATO
  AQUISICAO
}

enum StatusCliente {
  ATIVO
  PENDENTE
  INATIVO
}

model ContatoCliente {
  id        Int     @id @default(autoincrement())
  clienteId Int     @map("cliente_id")
  nome      String  @db.VarChar(200)
  celular   String? @db.VarChar(20)
  email     String? @db.VarChar(255)
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "contatos_clientes_cliente_id_fkey")
  @@map("contatos_clientes")
}

model Subcliente {
  id            Int            @id @default(autoincrement())
  clienteId     Int            @map("cliente_id")
  nome          String         @db.VarChar(200)
  cep           String?        @db.VarChar(10)
  logradouro    String?        @db.VarChar(255)
  numero        String?        @db.VarChar(20)
  complemento   String?        @db.VarChar(100)
  bairro        String?        @db.VarChar(100)
  cidade        String?        @db.VarChar(100)
  estado        String?        @db.VarChar(2)
  cpf           String?        @db.VarChar(20)
  email         String?        @db.VarChar(255)
  telefone      String?        @db.VarChar(20)
  cobrancaTipo  String?        @map("cobranca_tipo") @db.VarChar(20)
  ordensServico      OrdemServico[]
  pedidosRastreadores PedidoRastreador[]
  cliente            Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "subclientes_cliente_id_fkey")
  @@map("subclientes")
}

model Tecnico {
  id              Int            @id @default(autoincrement())
  nome            String         @db.VarChar(200)
  cpfCnpj         String?        @map("cpf_cnpj") @db.VarChar(20)
  telefone        String?        @db.VarChar(20)
  cidade          String?        @db.VarChar(100)
  estado          String?        @db.VarChar(2)
  cep             String?        @db.VarChar(10)
  logradouro      String?        @db.VarChar(255)
  numero          String?        @db.VarChar(20)
  complemento     String?        @db.VarChar(100)
  bairro          String?        @db.VarChar(100)
  cidadeEndereco  String?        @map("cidade_endereco") @db.VarChar(100)
  estadoEndereco  String?        @map("estado_endereco") @db.VarChar(2)
  ativo           Boolean        @default(true)
  ordensServico      OrdemServico[]
  precos             PrecoTecnico?
  aparelhos          Aparelho[]
  pedidosRastreadores PedidoRastreador[]

  @@map("tecnicos")
}

model PrecoTecnico {
  id                    Int     @id @default(autoincrement())
  tecnicoId             Int     @unique @map("tecnico_id")
  instalacaoComBloqueio Decimal @default(0.00) @map("instalacao_com_bloqueio") @db.Decimal(10, 2)
  instalacaoSemBloqueio Decimal @default(0.00) @map("instalacao_sem_bloqueio") @db.Decimal(10, 2)
  revisao               Decimal @default(0.00) @db.Decimal(10, 2)
  retirada              Decimal @default(0.00) @db.Decimal(10, 2)
  deslocamento          Decimal @default(0.00) @db.Decimal(10, 2)
  tecnico               Tecnico @relation(fields: [tecnicoId], references: [id], onDelete: Cascade)

  @@map("precos_tecnicos")
}

model Veiculo {
  id            Int            @id @default(autoincrement())
  placa         String         @unique @db.VarChar(10)
  marca         String         @db.VarChar(100)
  modelo        String         @db.VarChar(100)
  ano           Int?
  cor           String?        @db.VarChar(50)
  ordensServico OrdemServico[]

  @@map("veiculos")
}

model OrdemServico {
  id               Int           @id @default(autoincrement())
  numero           Int           @unique
  tipo             TipoOS
  status           StatusOS      @default(AGENDADO)
  clienteId        Int           @map("cliente_id")
  subclienteId     Int?          @map("subcliente_id")
  veiculoId        Int?          @map("veiculo_id")
  tecnicoId        Int?          @map("tecnico_id")
  criadoPorId      Int?          @map("criado_por_id")
  observacoes      String?       @db.Text
  idAparelho       String?       @map("id_aparelho") @db.VarChar(50)
  localInstalacao  String?       @map("local_instalacao") @db.VarChar(200)
  posChave         String?       @map("pos_chave") @db.VarChar(10)
  idEntrada        String?       @map("id_entrada") @db.VarChar(50)
  aparelhoEncontrado Boolean?    @map("aparelho_encontrado")
  subclienteSnapshotNome       String?  @map("subcliente_snapshot_nome") @db.VarChar(200)
  subclienteSnapshotLogradouro String?  @map("subcliente_snapshot_logradouro") @db.VarChar(255)
  subclienteSnapshotNumero     String?  @map("subcliente_snapshot_numero") @db.VarChar(20)
  subclienteSnapshotComplemento String? @map("subcliente_snapshot_complemento") @db.VarChar(100)
  subclienteSnapshotBairro     String?  @map("subcliente_snapshot_bairro") @db.VarChar(100)
  subclienteSnapshotCidade     String?  @map("subcliente_snapshot_cidade") @db.VarChar(100)
  subclienteSnapshotEstado     String?  @map("subcliente_snapshot_estado") @db.VarChar(2)
  subclienteSnapshotCep        String?  @map("subcliente_snapshot_cep") @db.VarChar(10)
  subclienteSnapshotCpf        String?  @map("subcliente_snapshot_cpf") @db.VarChar(20)
  subclienteSnapshotEmail      String?  @map("subcliente_snapshot_email") @db.VarChar(255)
  subclienteSnapshotTelefone   String?  @map("subcliente_snapshot_telefone") @db.VarChar(20)
  subclienteSnapshotCobrancaTipo String? @map("subcliente_snapshot_cobranca_tipo") @db.VarChar(20)
  criadoEm     DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime      @updatedAt @map("atualizado_em")
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoPor    Usuario?      @relation(fields: [criadoPorId], references: [id])
  subcliente   Subcliente?   @relation(fields: [subclienteId], references: [id])
  tecnico      Tecnico?      @relation(fields: [tecnicoId], references: [id])
  veiculo      Veiculo?      @relation(fields: [veiculoId], references: [id])
  historico    OSHistorico[]

  @@index([clienteId], map: "ordens_servico_cliente_id_fkey")
  @@index([criadoPorId], map: "ordens_servico_criado_por_id_fkey")
  @@index([subclienteId], map: "ordens_servico_subcliente_id_fkey")
  @@index([tecnicoId], map: "ordens_servico_tecnico_id_fkey")
  @@index([veiculoId], map: "ordens_servico_veiculo_id_fkey")
  @@map("ordens_servico")
}

model OSHistorico {
  id             Int          @id @default(autoincrement())
  ordemServicoId Int          @map("ordem_servico_id")
  statusAnterior StatusOS     @map("status_anterior")
  statusNovo     StatusOS     @map("status_novo")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  observacao     String?      @db.VarChar(500)
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)

  @@index([ordemServicoId], map: "os_historico_ordem_servico_id_fkey")
  @@map("os_historico")
}

enum TipoOS {
  INSTALACAO_COM_BLOQUEIO
  INSTALACAO_SEM_BLOQUEIO
  REVISAO
  RETIRADA
  DESLOCAMENTO
}

enum StatusOS {
  AGENDADO
  EM_TESTES
  TESTES_REALIZADOS
  AGUARDANDO_CADASTRO
  FINALIZADO
  CANCELADO
}

// ============= APARELHOS / EQUIPAMENTOS =============

model MarcaEquipamento {
  id                   Int                @id @default(autoincrement())
  nome                 String             @unique @db.VarChar(100)
  ativo                Boolean            @default(true)
  criadoEm             DateTime           @default(now()) @map("criado_em")
  modelos              ModeloEquipamento[]
  pedidosRastreadores  PedidoRastreador[]

  @@map("marcas_equipamentos")
}

model ModeloEquipamento {
  id                   Int                @id @default(autoincrement())
  nome                 String             @db.VarChar(100)
  marcaId              Int                @map("marca_id")
  ativo                Boolean            @default(true)
  criadoEm             DateTime           @default(now()) @map("criado_em")
  marca                MarcaEquipamento   @relation(fields: [marcaId], references: [id], onDelete: Cascade)
  pedidosRastreadores  PedidoRastreador[]

  @@unique([marcaId, nome])
  @@index([marcaId])
  @@map("modelos_equipamentos")
}

model Operadora {
  id                   Int                @id @default(autoincrement())
  nome                 String             @unique @db.VarChar(100)
  ativo                Boolean            @default(true)
  criadoEm             DateTime           @default(now()) @map("criado_em")
  marcasSimcard        MarcaSimcard[]
  pedidosRastreadores  PedidoRastreador[]

  @@map("operadoras")
}

model MarcaSimcard {
  id           Int           @id @default(autoincrement())
  nome         String        @db.VarChar(100)
  operadoraId  Int           @map("operadora_id")
  temPlanos    Boolean       @default(false) @map("tem_planos")
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now()) @map("criado_em")
  operadora    Operadora     @relation(fields: [operadoraId], references: [id], onDelete: Cascade)

  planos       PlanoSimcard[]
  aparelhos    Aparelho[]
  lotesAparelhos LoteAparelho[]

  @@unique([operadoraId, nome])
  @@index([operadoraId])
  @@map("marcas_simcard")
}

model PlanoSimcard {
  id             Int            @id @default(autoincrement())
  marcaSimcardId Int            @map("marca_simcard_id")
  planoMb        Int            @map("plano_mb")
  ativo          Boolean        @default(true)
  criadoEm       DateTime       @default(now()) @map("criado_em")
  marcaSimcard   MarcaSimcard   @relation(fields: [marcaSimcardId], references: [id], onDelete: Cascade)

  aparelhos      Aparelho[]
  lotesAparelhos LoteAparelho[]

  @@unique([marcaSimcardId, planoMb])
  @@index([marcaSimcardId])
  @@map("planos_simcard")
}

model Kit {
  id            Int        @id @default(autoincrement())
  nome          String     @unique @db.VarChar(100)
  criadoEm      DateTime   @default(now()) @map("criado_em")
  kitConcluido  Boolean    @default(false) @map("kit_concluido")
  aparelhos     Aparelho[]

  @@map("kits")
}

model Aparelho {
  id              Int               @id @default(autoincrement())
  tipo            TipoAparelho
  identificador   String?           @db.VarChar(50)
  status          StatusAparelho    @default(EM_ESTOQUE)
  proprietario    ProprietarioTipo  @default(INFINITY)
  clienteId       Int?              @map("cliente_id")
  marca           String?           @db.VarChar(100)
  modelo          String?           @db.VarChar(100)
  operadora       String?           @db.VarChar(50)
  marcaSimcardId  Int?              @map("marca_simcard_id")
  planoSimcardId  Int?              @map("plano_simcard_id")
  loteId          Int?              @map("lote_id")
  valorUnitario   Decimal?          @map("valor_unitario") @db.Decimal(10, 2)
  tecnicoId       Int?              @map("tecnico_id")
  kitId           Int?              @map("kit_id")
  simVinculadoId  Int?              @map("sim_vinculado_id")
  criadoEm        DateTime          @default(now()) @map("criado_em")
  atualizadoEm    DateTime          @updatedAt @map("atualizado_em")
  
  cliente         Cliente?          @relation(fields: [clienteId], references: [id])
  kit             Kit?              @relation(fields: [kitId], references: [id])
  lote            LoteAparelho?     @relation(fields: [loteId], references: [id])
  marcaSimcard    MarcaSimcard?     @relation(fields: [marcaSimcardId], references: [id])
  planoSimcard    PlanoSimcard?     @relation(fields: [planoSimcardId], references: [id])
  tecnico         Tecnico?          @relation(fields: [tecnicoId], references: [id])
  simVinculado    Aparelho?         @relation("SimVinculo", fields: [simVinculadoId], references: [id])
  aparelhosVinculados Aparelho[]    @relation("SimVinculo")
  historico       AparelhoHistorico[]

  @@index([clienteId])
  @@index([kitId])
  @@index([loteId])
  @@index([tecnicoId])
  @@index([simVinculadoId])
  @@index([marcaSimcardId])
  @@index([planoSimcardId])
  @@map("aparelhos")
}

model LoteAparelho {
  id              Int               @id @default(autoincrement())
  referencia      String            @db.VarChar(100)
  notaFiscal      String?           @map("nota_fiscal") @db.VarChar(50)
  dataChegada     DateTime          @map("data_chegada")
  tipo            TipoAparelho
  proprietario    ProprietarioTipo  @default(INFINITY)
  clienteId       Int?              @map("cliente_id")
  marca           String?           @db.VarChar(100)
  modelo          String?           @db.VarChar(100)
  operadora       String?           @db.VarChar(50)
  marcaSimcardId  Int?              @map("marca_simcard_id")
  planoSimcardId  Int?              @map("plano_simcard_id")
  quantidade      Int
  valorUnitario   Decimal           @map("valor_unitario") @db.Decimal(10, 2)
  valorTotal      Decimal           @map("valor_total") @db.Decimal(10, 2)
  criadoEm        DateTime          @default(now()) @map("criado_em")
  
  cliente         Cliente?          @relation(fields: [clienteId], references: [id])
  marcaSimcard    MarcaSimcard?     @relation(fields: [marcaSimcardId], references: [id])
  planoSimcard    PlanoSimcard?     @relation(fields: [planoSimcardId], references: [id])
  aparelhos       Aparelho[]

  @@index([clienteId])
  @@index([marcaSimcardId])
  @@index([planoSimcardId])
  @@map("lotes_aparelhos")
}

model AparelhoHistorico {
  id              Int               @id @default(autoincrement())
  aparelhoId      Int               @map("aparelho_id")
  statusAnterior  StatusAparelho    @map("status_anterior")
  statusNovo      StatusAparelho    @map("status_novo")
  observacao      String?           @db.VarChar(500)
  criadoEm        DateTime          @default(now()) @map("criado_em")
  
  aparelho        Aparelho          @relation(fields: [aparelhoId], references: [id], onDelete: Cascade)

  @@index([aparelhoId])
  @@map("aparelhos_historico")
}

enum TipoAparelho {
  RASTREADOR
  SIM
}

enum StatusAparelho {
  EM_ESTOQUE
  CONFIGURADO
  DESPACHADO
  COM_TECNICO
  INSTALADO
}

enum ProprietarioTipo {
  INFINITY
  CLIENTE
}

// ============= PEDIDOS DE RASTREADORES (AGENDAMENTO) =============

enum TipoDestinoPedido {
  TECNICO
  CLIENTE
}

enum StatusPedidoRastreador {
  SOLICITADO
  EM_CONFIGURACAO
  CONFIGURADO
  DESPACHADO
  ENTREGUE
}

enum UrgenciaPedido {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model PedidoRastreador {
  id                   Int                     @id @default(autoincrement())
  codigo               String                  @unique @db.VarChar(20)
  tipoDestino          TipoDestinoPedido
  tecnicoId            Int?                    @map("tecnico_id")
  clienteId            Int?                    @map("cliente_id")
  subclienteId         Int?                    @map("subcliente_id")
  deClienteId          Int?                    @map("de_cliente_id")
  quantidade           Int
  status               StatusPedidoRastreador  @default(SOLICITADO)
  urgencia             UrgenciaPedido          @default(MEDIA)
  dataSolicitacao      DateTime                @map("data_solicitacao")
  marcaEquipamentoId   Int?                    @map("marca_equipamento_id")
  modeloEquipamentoId  Int?                    @map("modelo_equipamento_id")
  operadoraId          Int?                    @map("operadora_id")
  criadoPorId          Int?                    @map("criado_por_id")
  observacao           String?                 @db.Text
  criadoEm             DateTime                @default(now()) @map("criado_em")
  atualizadoEm         DateTime                @updatedAt @map("atualizado_em")
  entregueEm           DateTime?               @map("entregue_em")
  kitIds               Json?                   @map("kit_ids")

  tecnico              Tecnico?                @relation(fields: [tecnicoId], references: [id])
  cliente              Cliente?                @relation("ClienteDestino", fields: [clienteId], references: [id])
  subcliente           Subcliente?             @relation(fields: [subclienteId], references: [id])
  deCliente            Cliente?                @relation("ClienteRemetente", fields: [deClienteId], references: [id])
  marcaEquipamento     MarcaEquipamento?       @relation(fields: [marcaEquipamentoId], references: [id])
  modeloEquipamento    ModeloEquipamento?      @relation(fields: [modeloEquipamentoId], references: [id])
  operadora            Operadora?              @relation(fields: [operadoraId], references: [id])
  criadoPor            Usuario?                @relation(fields: [criadoPorId], references: [id])
  historico            PedidoRastreadorHistorico[]

  @@index([tecnicoId])
  @@index([clienteId])
  @@index([subclienteId])
  @@index([deClienteId])
  @@index([criadoPorId])
  @@index([status])
  @@index([dataSolicitacao])
  @@index([marcaEquipamentoId])
  @@index([modeloEquipamentoId])
  @@index([operadoraId])
  @@map("pedidos_rastreadores")
}

model PedidoRastreadorHistorico {
  id                 Int                   @id @default(autoincrement())
  pedidoRastreadorId Int                   @map("pedido_rastreador_id")
  statusAnterior     StatusPedidoRastreador @map("status_anterior")
  statusNovo         StatusPedidoRastreador @map("status_novo")
  observacao         String?               @db.VarChar(500)
  criadoEm           DateTime              @default(now()) @map("criado_em")

  pedidoRastreador   PedidoRastreador      @relation(fields: [pedidoRastreadorId], references: [id], onDelete: Cascade)

  @@index([pedidoRastreadorId])
  @@map("pedidos_rastreadores_historico")
}
