generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id            Int            @id @default(autoincrement())
  nome          String         @db.VarChar(200)
  email         String         @unique @db.VarChar(255)
  senhaHash     String         @map("senha_hash") @db.VarChar(255)
  ativo         Boolean        @default(true)
  setor         SetorUsuario?
  ultimoAcesso  DateTime?      @map("ultimo_acesso")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  ordensServico OrdemServico[]
  usuarioCargos UsuarioCargo[]

  @@map("usuarios")
}

enum SetorUsuario {
  AGENDAMENTO
  CONFIGURACAO
  ADMINISTRATIVO
}

model Setor {
  id     Int     @id @default(autoincrement())
  code   String  @unique @db.VarChar(50)
  nome   String  @db.VarChar(100)
  cargos Cargo[]

  @@map("setores")
}

model Cargo {
  id              Int              @id @default(autoincrement())
  setorId         Int              @map("sector_id")
  code            String           @db.VarChar(50)
  nome            String           @db.VarChar(100)
  descricao       String?          @db.VarChar(500)
  categoria       CategoriaCargo   @default(OPERACIONAL)
  ativo           Boolean          @default(true)
  setor           Setor            @relation(fields: [setorId], references: [id], onDelete: Cascade)
  cargoPermissoes CargoPermissao[]
  usuarioCargos   UsuarioCargo[]

  @@unique([setorId, code])
  @@map("cargos")
}

enum CategoriaCargo {
  OPERACIONAL
  ADMINISTRATIVO
  GESTAO
}

model Permissao {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(100)
  cargoPermissoes CargoPermissao[]

  @@map("permissoes")
}

model CargoPermissao {
  cargoId     Int       @map("role_id")
  permissaoId Int       @map("permission_id")
  permissao   Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)
  cargo       Cargo     @relation(fields: [cargoId], references: [id], onDelete: Cascade)

  @@id([cargoId, permissaoId])
  @@index([permissaoId], map: "cargos_permissoes_permission_id_fkey")
  @@map("cargos_permissoes")
}

model UsuarioCargo {
  usuarioId Int     @map("user_id")
  cargoId   Int     @map("role_id")
  cargo     Cargo   @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([usuarioId, cargoId])
  @@index([cargoId], map: "usuarios_cargos_role_id_fkey")
  @@map("usuarios_cargos")
}

model RegistroAuditoria {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?     @map("user_id")
  action      String   @db.VarChar(50)
  entity      String   @db.VarChar(100)
  entityId    Int?     @map("entity_id")
  createdAt   DateTime @default(now()) @map("created_at")
  payloadJson String?  @map("payload_json") @db.Text

  @@map("registros_auditoria")
}

model Cliente {
  id             Int              @id @default(autoincrement())
  nome           String           @db.VarChar(200)
  nomeFantasia   String?          @map("nome_fantasia") @db.VarChar(200)
  cnpj           String?          @db.VarChar(20)
  tipoContrato   TipoContrato     @default(COMODATO) @map("tipo_contrato")
  estoqueProprio Boolean          @default(false) @map("estoque_proprio")
  status         StatusCliente    @default(ATIVO)
  contatos       ContatoCliente[]
  ordensServico  OrdemServico[]
  subclientes    Subcliente[]

  @@map("clientes")
}

enum TipoContrato {
  COMODATO
  AQUISICAO
}

enum StatusCliente {
  ATIVO
  PENDENTE
  INATIVO
}

model ContatoCliente {
  id        Int     @id @default(autoincrement())
  clienteId Int     @map("cliente_id")
  nome      String  @db.VarChar(200)
  celular   String? @db.VarChar(20)
  email     String? @db.VarChar(255)
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "contatos_clientes_cliente_id_fkey")
  @@map("contatos_clientes")
}

model Subcliente {
  id            Int            @id @default(autoincrement())
  clienteId     Int            @map("cliente_id")
  nome          String         @db.VarChar(200)
  cep           String?        @db.VarChar(10)
  cidade        String?        @db.VarChar(100)
  estado        String?        @db.VarChar(2)
  cpf           String?        @db.VarChar(14)
  email         String?        @db.VarChar(255)
  telefone      String?        @db.VarChar(20)
  cobrancaTipo  String?        @map("cobranca_tipo") @db.VarChar(20)
  ordensServico OrdemServico[]
  cliente       Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "subclientes_cliente_id_fkey")
  @@map("subclientes")
}

model Tecnico {
  id              Int            @id @default(autoincrement())
  nome            String         @db.VarChar(200)
  telefone        String?        @db.VarChar(20)
  cidade          String?        @db.VarChar(100)
  estado          String?        @db.VarChar(2)
  cep             String?        @db.VarChar(10)
  logradouro      String?        @db.VarChar(255)
  numero          String?        @db.VarChar(20)
  complemento     String?        @db.VarChar(100)
  bairro          String?        @db.VarChar(100)
  cidadeEndereco  String?        @map("cidade_endereco") @db.VarChar(100)
  estadoEndereco  String?        @map("estado_endereco") @db.VarChar(2)
  ativo           Boolean        @default(true)
  ordensServico   OrdemServico[]
  precos          PrecoTecnico?

  @@map("tecnicos")
}

model PrecoTecnico {
  id                    Int     @id @default(autoincrement())
  tecnicoId             Int     @unique @map("tecnico_id")
  instalacaoComBloqueio Decimal @default(0.00) @map("instalacao_com_bloqueio") @db.Decimal(10, 2)
  instalacaoSemBloqueio Decimal @default(0.00) @map("instalacao_sem_bloqueio") @db.Decimal(10, 2)
  revisao               Decimal @default(0.00) @db.Decimal(10, 2)
  retirada              Decimal @default(0.00) @db.Decimal(10, 2)
  deslocamento          Decimal @default(0.00) @db.Decimal(10, 2)
  tecnico               Tecnico @relation(fields: [tecnicoId], references: [id], onDelete: Cascade)

  @@map("precos_tecnicos")
}

model Veiculo {
  id            Int            @id @default(autoincrement())
  placa         String         @unique @db.VarChar(10)
  marca         String         @db.VarChar(100)
  modelo        String         @db.VarChar(100)
  ano           Int?
  cor           String?        @db.VarChar(50)
  ordensServico OrdemServico[]

  @@map("veiculos")
}

model OrdemServico {
  id           Int           @id @default(autoincrement())
  numero       Int           @unique
  tipo         TipoOS
  status       StatusOS      @default(AGENDADO)
  clienteId    Int           @map("cliente_id")
  subclienteId Int?          @map("subcliente_id")
  veiculoId    Int?          @map("veiculo_id")
  tecnicoId    Int?          @map("tecnico_id")
  criadoPorId  Int?          @map("criado_por_id")
  observacoes  String?       @db.Text
  criadoEm     DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime      @updatedAt @map("atualizado_em")
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoPor    Usuario?      @relation(fields: [criadoPorId], references: [id])
  subcliente   Subcliente?   @relation(fields: [subclienteId], references: [id])
  tecnico      Tecnico?      @relation(fields: [tecnicoId], references: [id])
  veiculo      Veiculo?      @relation(fields: [veiculoId], references: [id])
  historico    OSHistorico[]

  @@index([clienteId], map: "ordens_servico_cliente_id_fkey")
  @@index([criadoPorId], map: "ordens_servico_criado_por_id_fkey")
  @@index([subclienteId], map: "ordens_servico_subcliente_id_fkey")
  @@index([tecnicoId], map: "ordens_servico_tecnico_id_fkey")
  @@index([veiculoId], map: "ordens_servico_veiculo_id_fkey")
  @@map("ordens_servico")
}

model OSHistorico {
  id             Int          @id @default(autoincrement())
  ordemServicoId Int          @map("ordem_servico_id")
  statusAnterior StatusOS     @map("status_anterior")
  statusNovo     StatusOS     @map("status_novo")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  observacao     String?      @db.VarChar(500)
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)

  @@index([ordemServicoId], map: "os_historico_ordem_servico_id_fkey")
  @@map("os_historico")
}

enum TipoOS {
  INSTALACAO_COM_BLOQUEIO
  INSTALACAO_SEM_BLOQUEIO
  REVISAO
  RETIRADA
  DESLOCAMENTO
}

enum StatusOS {
  AGENDADO
  EM_TESTES
  TESTES_REALIZADOS
  AGUARDANDO_CADASTRO
  FINALIZADO
  CANCELADO
}
